# Server Configuration
PORT=5000

# Database Configuration
# For local development: mongodb://localhost:27017/task-management
# For production (MongoDB Atlas): mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://chouhandnick_db_user:meNiraj@cluster0.tuqnqce.mongodb.net/?appName=Cluster0

# JWT Configuration
# Generate a secure random string for production (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here

# Environment (development, production, test)
NODE_ENV=development

# Frontend URL(s) - comma-separated for multiple origins
# For local development: http://localhost:3000,http://localhost:5173
# For production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# HTTPS Enforcement (set to 'true' in production)
ENFORCE_HTTPS=false
